package Missao.main;

import java.util.ArrayList;
import java.util.Scanner;

 public class Missao {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        ArrayList<Foguete> foguetes = new ArrayList<>();
        ArrayList<Satelite> satelites = new ArrayList<>();
        int opcao;
        do {
            System.out.println("1-Adicionar Foguete \uD83D\uDE80 ");
            System.out.println("2-Adicionar Satélite \uD83D\uDEF0\uFE0F ");
            System.out.println("3-Mostrar oq tu fez até agr \uD83E\uDD2F");
            System.out.println("4-Simular Lançamento");
            System.out.println("5-Sair");
            System.out.print("Faz oq tu quer aí: ");
            opcao = sc.nextInt();
            sc.nextLine(); // limpar buffer
            switch (opcao) {
                case 1:
                    System.out.print("Nome do foguete \uD83D\uDE80: ");
                    String nomeF = sc.nextLine();
                    System.out.print("Carga: ");
                    float capacidade = sc.nextFloat();
                    System.out.print("Combustível: ");
                    float combustivel = sc.nextFloat();
                    sc.nextLine();
                    System.out.print("Status (Tripulado-Não tripulado):");
                    String statusF = sc.nextLine();
                    System.out.print("Temperatura: ");
                    float temperatura = sc.nextFloat();
                    sc.nextLine();
                    foguetes.add(new Foguete(nomeF, capacidade, combustivel, statusF, temperatura));
                    System.out.println("Foguete adicionado!");
                    break;
                case 2:
                    System.out.print("Nome do satélite \uD83D\uDEF0\uFE0F: ");
                    String nomeS = sc.nextLine();
                    System.out.print("Massa: ");
                    float massa = sc.nextFloat();
                    sc.nextLine();
                    System.out.print("Órbita (LEO-GEO-LUNAR):");
                    String orbita = sc.nextLine();
                    System.out.print("Energia: ");
                    float energia = sc.nextFloat();
                    sc.nextLine();
                    System.out.print("Observações (Espionagem-Localização-Cominucação):");
                    String obs = sc.nextLine();
                    String tempoOrbita;
                    System.out.println("Tempo em órbita:");
                    System.out.println("1 - 7 meses");
                    System.out.println("2 - 1 ano e 4 meses");
                    System.out.println("3 - 2 anos");
                    System.out.print("Escolha: ");
                    int opcaoTempo = sc.nextInt();
                    sc.nextLine();
                    switch (opcaoTempo) {
                        case 1:
                            tempoOrbita = "7 meses";
                            break;
                        case 2:
                            tempoOrbita = "1 ano e 4 meses";
                            break;
                        case 3:
                            tempoOrbita = "2 anos";
                            break;
                        default:
                            tempoOrbita = "Indefinido";
                            break;
                    }
                    satelites.add(new Satelite(nomeS, massa, orbita, energia, obs, tempoOrbita));
                    System.out.println("Satélite adicionado! 🛰️");
                case 3:
                    System.out.println("\n--Foguetões--\uD83D\uDE80:");
                    for (Foguete f : foguetes) {
                        System.out.println(f);
                        System.out.println("---");
                    }
                    System.out.println("\n--Satélitões--\uD83D\uDEF0\uFE0F:");
                    for (Satelite s : satelites) {
                        System.out.println(s);
                        System.out.println("---");
                    }
                    break;
                case 4:
                    if (foguetes.isEmpty()) {
                        System.out.println("Nenhum foguete encontrado!");
                        break;
                    }
                    Foguete f = foguetes.get(0);
                    System.out.println("\nAbastecendo foguete...");
                    f.abastecer(100);
                    System.out.println("Tentando lançar...");
                    if (f.lancar()) {
                        System.out.println("Lançamento deu certo!");
                        if (!satelites.isEmpty()) {
                            Satelite s = satelites.get(0);
                            s.ativar_paineis();
                            s.enviar_dados("Dados enviados!");
                        }
                    } else {
                        System.out.println("Falha no lançamento! Morreu td mundo =( ");
                    }
                    break;
            }
        } while (opcao != 5);
    }
}
