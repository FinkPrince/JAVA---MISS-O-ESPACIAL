package CentroControle;


public class Satelite {

    private String observacoes;
    private String nome;
    private float massa;
    private String orbita_alvo;
    private float energia;
    private String status;

    public String getSat(){
        return nome;
    }
    public String setStatus(){
        return nome;
    }
    public Satelite(String nome, float massa, String orbita_alvo, float energia, String status, String observacoes){
        this.nome = nome;
        this.massa = massa;
        this.orbita_alvo = orbita_alvo;
        this.energia = energia;
        this.status = status;
        this.observacoes = observacoes;
    }

    public void ativar_paineis(){
        energia += 20;

        if(energia > 100){
            energia = 100;
        }
    }
    public String getObservacao(){
        return observacoes;
    }

    public void setObservacao(String observacao){
        this.observacoes = observacao;
    }

    public void enviar_dados(String mensagem){
        if(status.equals("Ativo")){
            System.out.println("Satelite " + nome + " enviando: " + mensagem);
        }
    }

    public void relatorio(){
        System.out.println("Nome: " + nome);
        System.out.println("Massa: " + massa);
        System.out.println("Orbita: " + orbita_alvo);
        System.out.println("Energia: " + energia);
        System.out.println("Status: " + status);
        System.out.println("Observações: " + observacoes);
    }
    @Override
    public String toString(){
        return "Satelite:" +nome+
                "\nOrbita:" +orbita_alvo+
                "\nEnergia:" +energia+
                "\nStatus:" +status+
                "\nObservacoes: " +observacoes;
    }
}
